{
  "version": "3.0.0",
  "agent_id": "3f19f8b6-071b-4084-80ad-fcd27640aef1",
  "metadata": {
    "name": "Luna - Travel Guru",
    "slug": "luna-travel-guru",
    "description": "Asistente de viajes premium con soporte para reservas, itinerarios y clima local.",
    "tags": [
      "travel",
      "premium",
      "multilingual",
      "concierge"
    ],
    "language": "es-CO"
  },
  "architecture": {
    "type": "pipeline",
    "config": {
      "resilience": {
        "type": "anthropic",
        "fallback_provider": "openai",
        "fallback_model": "gpt-4o",
        "health_check_interval_ms": 5000
      }
    }
  },
  "brain": {
    "llm": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-20241022",
      "config": {
        "temperature": 0.7,
        "max_tokens": 4096,
        "top_p": 0.9
      },
      "instructions": "# Identidad\n- Eres Luna, una experta conserje de viajes de alto nivel. Eres sofisticada, eficiente y siempre buscas superar las expectativas del cliente.\n\n# Objetivos\n- Ayudar a los viajeros a planificar sus rutas ideales.\n- Proporcionar recomendaciones gastronómicas y culturales basadas en la ubicación.\n- Mantener un registro claro de las preferencias del usuario.\n\n# Guía de Estilo\n- Tono: Elegante y acogedor.\n- Pausas: Usa ' - ' para respiraciones naturales.\n- CRÍTICO: Nunca digas 'soy una IA', actúa como una asistente personal humana.\n"
    },
    "knowledge_base": {
      "id": "kb_travel_policies_2026"
    },
    "localization": {
      "default_locale": "es-CO",
      "timezone": "America/Bogota",
      "currency": "COP",
      "number_format": "dot_decimal"
    }
  },
  "runtime_profiles": {
    "stt": {
      "provider": "deepgram",
      "model": "nova-3-general",
      "language": "es"
    },
    "tts": {
      "provider": "cartesia",
      "voice_id": "79a125e8-cd45-4c13-8a67-188112f4dd22",
      "speed": 1.0,
      "language": "es"
    },
    "vad": {
      "provider": "silero",
      "params": {
        "min_silence_duration_ms": 400
      }
    },
    "behavior": {
      "interruptibility": true,
      "initial_action": "SPEAK_FIRST",
      "streaming": true,
      "ambient_sound": {
        "audio": "office_ambience",
        "volume": 0.2,
        "enabled": true
      },
      "thinking_sound": {
        "audio": "light_hum",
        "volume": 0.4,
        "enabled": true
      }
    },
    "session_limits": {
      "max_duration": {
        "message": "Ha sido un placer asistirte en tu viaje. ¡Buen vuelo!",
        "time_in_minutes": 45
      },
      "inactivity_timeout": {
        "enabled": true,
        "steps": [
          {
            "message": ["¿Deseas continuar con tu reserva?", "¿Sigues ahí?"],
            "wait_seconds": 20
          }
        ],
        "final_message": "Terminaré la llamada por ahora. Que tengas un excelente viaje.",
        "total_timeout_seconds": 90
      }
    }
  },
  "capabilities": {
    "tools": [
      {
        "name": "search_flights",
        "type": "function_call",
        "api_endpoint": "https://api.travel.ai/v1/flights/search",
        "timeout_ms": 5000,
        "disabled": false
      },
      {
        "name": "get_weather",
        "type": "function_call",
        "api_endpoint": "https://api.travel.ai/v1/weather",
        "disabled": false
      }
    ],
    "mcp_servers": [],
    "guardrails": {
      "pii_redaction": true,
      "financial_compliance_check": false,
      "sensitive_topics_filter": ["politics"],
      "strict_email_privacy": true
    },
    "handoff": {
      "enabled": true,
      "trigger_phrases": ["quiero hablar con un supervisor", "agente humano"],
      "method": "sip_transfer",
      "target": "sip:concierge@travel.ai",
      "context_transfer": true
    }
  },
  "orchestration": {
    "channels": {
      "web": {
        "enabled": true,
        "transport": {
          "type": "daily",
          "available_providers": ["daily"],
          "daily": {
            "enabled": true,
            "config": {
              "theme": "light",
              "proxy": "direct"
            }
          }
        },
        "ui": {
          "type": "widget",
          "theme": {
            "primary_color": "#FFC107",
            "variant": "glassmorphism",
            "font": "Outfit",
            "dark_mode": false
          },
          "launcher": {
            "label": "Planea tu viaje",
            "position": "bottom-right",
            "icon": "flight"
          }
        }
      }
    }
  },
  "compliance": {
    "data_retention_days": 15,
    "recording_storage": "s3-encrypted",
    "gdpr_compliant": true,
    "audit_logs_enabled": true
  },
  "observability": {
    "logging_level": "info",
    "tracing": "langsmith",
    "prompts": {
      "analysis_successful": "Evalúa si Luna logró deleitar al viajero.",
      "analysis_summary": "Resume el itinerario acordado."
    }
  }
}
